{
  "name": "drive",
  "version": "1.0.0",
  "description": "Drive monorepo",
  "main": "index.js",
  "scripts": {
    "old-dev": "concurrently 'cd frontend && npm run dev' 'cd worker && wrangler dev --remote'",
    "dev": "sst dev --stage dev",
    "prepare": "husky install",
    "deploy": "NODE_ENV=production sst deploy --stage=production"
  },
  "author": "Hydrophobefireman",
  "license": "MIT",
  "private": true,
  "dependencies": {
    "@pulumi/cloudflare": "^6.13.0",
    "@pulumi/command": "^1.2.1",
    "husky": "^8.0.3",
    "sst": "^4.1.10 "
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260305.1",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.70.0"
  }
}
